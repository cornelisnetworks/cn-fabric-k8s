FROM golang:1.25-alpine AS builder

WORKDIR /workspace

# Install build dependencies
RUN apk add --no-cache make git

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY cmd/ cmd/
COPY pkg/ pkg/

# Build
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -a -o cn-rdma-shared-dp ./cmd/cn-rdma-shared-dp

FROM alpine:latest

WORKDIR /

# Copy binary from builder
COPY --from=builder /workspace/cn-rdma-shared-dp /usr/bin/cn-rdma-shared-dp

# Create CDI spec directory
RUN mkdir -p /var/run/cdi

ENTRYPOINT ["/usr/bin/cn-rdma-shared-dp"]
